{
  "enabled": true,
  "name": "Test on Save",
  "description": "Ejecuta los tests relacionados al guardar archivos de código.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "filePatterns": ["**/*.ts", "**/*.vue"]
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run --reporter=verbose"
  }
}
