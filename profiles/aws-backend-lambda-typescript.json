{
  "id": "aws-backend-lambda-typescript",
  "phase": 1,
  "enabled": true,
  "name": "AWS Backend Lambda (TypeScript)",
  "description": "Funciones Lambda AWS-first con TypeScript.",
  "dimensions": {
    "cloud": "aws",
    "workload": "backend-worker",
    "runtime": "typescript",
    "provisioner": "none",
    "framework": "none",
    "features": ["lambda", "typescript"]
  },
  "wizard": {
    "workload": "backend-worker",
    "runtime": "typescript"
  },
  "detection": {
    "priority": 225,
    "requiredFiles": ["package.json"],
    "packageJsonDependencies": ["@aws-sdk/*"],
    "anyGlobs": ["handlers/**/*.ts", "src/handlers/**/*.ts", "functions/**/*.ts"]
  },
  "tooling": {
    "linters": ["eslint"],
    "formatters": ["prettier"],
    "tests": ["vitest"],
    "typecheck": ["tsc"],
    "aws": ["awscli", "node"],
    "notes": ["Alinear bundling, runtime y scripts Node.js."]
  },
  "agents": ["orbit", "aws-architect", "aws-lambda-typescript", "aws-iam-security", "aws-observability", "aws-test-quality"],
  "steeringPacks": ["core", "git", "security", "aws-shared", "runtime-typescript", "lambda", "testing", "observability"],
  "localSkills": ["orbit-bootstrap", "typescript-runtime", "aws-lambda-typescript", "aws-testing", "aws-observability"],
  "remoteSkills": ["supercent-code-review"],
  "hooks": ["node-format-on-save.kiro.hook", "node-lint-on-save.kiro.hook", "node-test-after-task.kiro.hook"],
  "extensionPacks": ["base", "typescript-aws"],
  "validations": [
    {
      "tool": "node",
      "command": "node --version",
      "minVersion": "18.0.0",
      "required": true,
      "installHint": "brew install node (macOS) | sudo apt install nodejs (Linux)"
    },
    {
      "tool": "npm",
      "command": "npm --version",
      "minVersion": "9.0.0",
      "required": true,
      "installHint": "Se instala con Node.js"
    },
    {
      "tool": "aws",
      "command": "aws --version",
      "minVersion": "2.0.0",
      "required": true,
      "installHint": "brew install awscli (macOS) | sudo apt install awscli (Linux)"
    }
  ],
  "envCheck": {
    "files": [".env", ".env.local"],
    "requiredVars": []
  },
  "awsCheck": true
}
