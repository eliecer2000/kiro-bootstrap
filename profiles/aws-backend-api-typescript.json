{
  "id": "aws-backend-api-typescript",
  "phase": 1,
  "enabled": true,
  "name": "AWS Backend API (TypeScript)",
  "description": "Servicio API AWS-first con runtime TypeScript.",
  "dimensions": {
    "cloud": "aws",
    "workload": "backend-api",
    "runtime": "typescript",
    "provisioner": "none",
    "framework": "none",
    "features": ["api", "serverless", "typescript"]
  },
  "wizard": {
    "workload": "backend-api",
    "runtime": "typescript"
  },
  "detection": {
    "priority": 205,
    "requiredFiles": ["package.json"],
    "packageJsonDependencies": ["@aws-sdk/*"],
    "anyGlobs": ["api/**/*.ts", "src/api/**/*.ts", "src/**/*.ts"]
  },
  "tooling": {
    "linters": ["eslint"],
    "formatters": ["prettier"],
    "tests": ["vitest"],
    "typecheck": ["tsc"],
    "aws": ["awscli", "node"],
    "notes": ["Mantener scripts lint, format, test y typecheck."]
  },
  "agents": ["orbit", "aws-architect", "aws-api-integration", "aws-iam-security", "aws-observability", "aws-test-quality"],
  "steeringPacks": ["core", "git", "security", "aws-shared", "runtime-typescript", "api", "testing", "observability"],
  "localSkills": ["orbit-bootstrap", "find-skills", "typescript-runtime", "aws-api", "aws-serverless", "aws-testing", "aws-observability"],
  "remoteSkills": ["supercent-api-documentation"],
  "hooks": ["node-format-on-save.kiro.hook", "node-lint-on-save.kiro.hook", "node-test-after-task.kiro.hook"],
  "extensionPacks": ["base", "typescript-aws"],
  "validations": [
    {
      "tool": "git",
      "command": "git --version",
      "minVersion": "2.30.0",
      "required": true,
      "installHint": "brew install git (macOS) | sudo apt install git (Linux)"
    },
    {
      "tool": "node",
      "command": "node --version",
      "minVersion": "18.0.0",
      "required": true,
      "installHint": "brew install node (macOS) | sudo apt install nodejs (Linux)"
    },
    {
      "tool": "npm",
      "command": "npm --version",
      "minVersion": "9.0.0",
      "required": true,
      "installHint": "Se instala con Node.js"
    },
    {
      "tool": "aws",
      "command": "aws --version",
      "minVersion": "2.0.0",
      "required": true,
      "installHint": "brew install awscli (macOS) | sudo apt install awscli (Linux)"
    }
  ],
  "envCheck": {
    "files": [".env", ".env.local"],
    "requiredVars": []
  },
  "awsCheck": true
}
